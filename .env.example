# ============================================================
# FiDo — Variables de entorno
# ============================================================
# Copia este archivo como .env y rellena los valores reales:
#   cp .env.example .env
#
# El archivo .env NUNCA se sube a git (está en .gitignore).
# ============================================================

# ── NTFY (intermediario de transporte para captura desde el móvil) ──────────
# Topic privado para recibir movimientos bancarios desde Tasker.
# Generar con: python -c "import secrets; print('fido-mov-' + secrets.token_hex(8))"
# Si está vacío, el listener se desactiva.
NTFY_TOPIC=

# URL del servidor NTFY (el público es https://ntfy.sh)
NTFY_URL=https://ntfy.sh

# ID de la cuenta que se usará si el mensaje no especifica ninguna (opcional)
NTFY_CUENTA_DEFAULT=
